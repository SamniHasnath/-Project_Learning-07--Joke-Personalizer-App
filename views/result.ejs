<!DOCTYPE html>
<html>
<head>
  <title>Your Joke</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      height: 100vh;
      background: linear-gradient(135deg, #ffecd2, #fcb69f);
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: Arial;
    }

    .card {
      width: 500px;
      border-radius: 20px;
      padding: 25px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      text-align: center;
    }

    .joke {
      font-size: 18px;
      margin-top: 20px;
    }

    .btn {
      margin-top: 20px;
    }
  </style>
</head>

<body>

  <div class="card bg-white">

    <h3>👋 Hello <%= name %></h3>

    <div class="alert alert-success joke">
      <%= joke %>
    </div>

    <a href="/" class="btn btn-primary">🔁 Try Another Joke</a>

  </div>

</body>
</html>